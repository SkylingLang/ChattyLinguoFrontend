APP_NAME=ChattyLinguo
APP_ENV=local
DEBUG=true
API_BASE_URL=https://your-domain.com
MINI_APP_URL=https://your-mini-app-domain.com

DATABASE_URL=postgresql+asyncpg://chatty:change-me@localhost:5432/chattylinguo

TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me

OPENAI_API_KEY=replace-me
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_DEFAULT_VOICE=alloy

FREE_DAILY_MESSAGE_LIMIT=25
FREE_DAILY_AUDIO_LIMIT=10
